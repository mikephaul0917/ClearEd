erDiagram
    Announcement {
        string title
        string content
        maintenance_or_policy_or_security_or_general_or_urgent type
        low_or_medium_or_high_or_critical priority
        all_or_institutions_or_students_or_admins_or_super_admin targetAudience
        ObjectId targetInstitutions
        boolean isActive
        Date scheduledAt
        Date expiresAt
        ObjectId createdBy
        Date createdAt
        Date updatedAt
        number viewCount
        number dismissCount
        boolean requiresAcknowledgment
        string attachments
        string tags
    }
    Announcement }o--|| User : "createdBy"
    Announcement }o--|{ Institution : "targetInstitutions"
    AnnouncementAcknowledgment {
        ObjectId announcement
        ObjectId user
        ObjectId institution
        Date acknowledgedAt
        string ipAddress
        string userAgent
    }
    AnnouncementAcknowledgment }o--|| Announcement : "announcement"
    AnnouncementAcknowledgment }o--|| User : "user"
    AnnouncementAcknowledgment }o--|| Institution : "institution"
